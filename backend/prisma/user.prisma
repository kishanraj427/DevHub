model User {
  id          String    @id @default(cuid())
  email       String    @unique
  password    String    // hashed
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  snippets    Snippet[]
  collections Collection[]
  stars       Star[]
  forks       Fork[]
}