{
  "$schema": "https://biomejs.dev/schemas/2.4.5/schema.json",
  "root": true,
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "files": {
    "includes": [
      "**",
      "!**/node_modules",
      "!**/dist",
      "!**/src/generated",
      "!**/src/routeTree.gen.ts",
      "!**/*.css"
    ]
  },
  "overrides": [
    {
      "includes": ["frontend/**"],
      "formatter": {
        "indentStyle": "tab"
      },
      "javascript": {
        "formatter": {
          "quoteStyle": "double"
        }
      }
    }
  ]
}
